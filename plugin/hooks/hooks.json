{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/prime.sh ${user_config.plan_review} ${user_config.ui_mockups} ${user_config.diagrams}",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_scratchtml_scratchtml__(share_document|upload_document)",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/open-plan.sh ${user_config.auto_open} ${user_config.ui_mockups} ${user_config.approve_mode}",
            "timeout": 10,
            "statusMessage": "Opening document in browser…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/plan-review.sh ${user_config.plan_review} ${user_config.approve_mode} ${user_config.ui_mockups} ${user_config.diagrams}",
            "timeout": 10,
            "statusMessage": "scratchtml plan review…"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/approve-plan.sh ${user_config.approve_mode}",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
